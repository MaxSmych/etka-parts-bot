# ===== Обязательные =====
BOT_TOKEN=123456789:replace_with_your_bot_token

# ===== Прокси для Telegram (если api.telegram.org недоступен напрямую) =====
# SOCKS5-прокси ТОЛЬКО для Telegram Bot API. Пусто = коннект напрямую.
# Схема ТОЛЬКО socks5:// (НЕ socks5h:// — aiogram сам резолвит DNS через прокси,
# а python-socks не понимает схему socks5h и упадёт с "Invalid scheme component").
# Формат: socks5://user:pass@host:port
TG_PROXY=

# Claude (мозг-подборщик запчастей) — ОБЯЗАТЕЛЬНО
ANTHROPIC_API_KEY=sk-replace_with_your_anthropic_or_gateway_token
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-opus-4-8
# Модель для категоризации (можно тот же или более лёгкий)
CLAUDE_MODEL_PICK=claude-opus-4-8

# ===== Машина (контекст подбора) =====
# VIN машины (для ETKA и подбора по названию)
CAR_VIN=
# Двигатель (тип+объём+код, напр. "2.0 TDI CBAB") — сильно влияет на артикулы
CAR_ENGINE=
# Путь к файлу с заводским build-sheet (ETKA/VIN-декод с PR-кодами)
CAR_PROFILE_FILE=VIN.txt

# ===== Superetka (онлайн-ETKA) =====
SUPERETKA_LOGIN=
SUPERETKA_PASSWORD=

# ===== Emex (реальные цены по аккаунту) =====
EMEX_LOGIN=
EMEX_PASSWORD=

# ===== OpenAI Whisper (голосовой ввод, необязательно) =====
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
